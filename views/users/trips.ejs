<% layout("/layouts/boilerplate") %>

 <div class="trips-nav">
    <a href="/listings" class="back-home-btn">
        <i class="fa-solid fa-arrow-left"></i> Back to Home
    </a>
</div>

<div class="container mt-4">
    <div class="trips-header">
        <h1 class="mb-4">My Trips</h1>
        <div class="trip-tabs">
            <a href="/trips" class="trip-tab active">Upcoming</a>
            <a href="/trips/past" class="trip-tab">Past</a>
        </div>
    </div>
    
    <% if(bookings.length === 0) { %>
        <div class="text-center py-5">
            <i class="fa-regular fa-calendar" style="font-size: 4rem; color: #ff385c;"></i>
            <h3 class="mt-3">No upcoming trips</h3>
            <p class="text-muted">Start planning your next adventure!</p>
            <a href="/listings" class="btn btn-dark mt-3">Explore Listings</a>
        </div>
    <% } else { %>
        <div class="trips-list">
            <% for(let booking of bookings) { %>
                <div class="trip-card">
                    <div class="trip-image">
                        <a href="/listings/<%= booking.listing._id %>">
                            <img src="<%= booking.listing.image.url %>" alt="<%= booking.listing.title %>">
                        </a>
                    </div>
                    <div class="trip-details">
                        <div class="trip-header">
                            <h3><%= booking.listing.title %></h3>
                            <span class="trip-status <%= booking.status %>"> 
                                 <%= booking.status.charAt(0).toUpperCase() + booking.status.slice(1) %></span>
                        </div>
                        <p class="trip-location">
                            <i class="fa-regular fa-map"></i> <%= booking.listing.location %>, <%= booking.listing.country %>
                        </p>
                        <div class="trip-dates">
                            <div class="date-box">
                                <label>CHECK-IN</label>
                                <span><%= new Date(booking.checkIn).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                            </div>
                            <div class="date-box">
                                <label>CHECKOUT</label>
                                <span><%= new Date(booking.checkOut).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                            </div>
                            <div class="date-box">
                                <label>GUESTS</label>
                                <span><%= booking.guests %> <%= booking.guests === 1 ? 'guest' : 'guests' %></span>
                            </div>
                        </div>
                        <div class="trip-footer">
                            <div class="trip-price">
                                <span class="price-label">Total paid:</span>
                                <span class="price-value">₹<%= booking.totalPrice.toLocaleString("en-IN") %></span>
                            </div>
                            <div class="trip-actions">
                                <a href="/bookings/<%= booking._id %>" class="details-btn">Details</a>
                                <% 
                                    const now = new Date();
                                    const checkIn = new Date(booking.checkIn);
                                    const hoursUntilCheckIn = (checkIn - now) / (1000 * 60 * 60);
                                %>
                                <% if(   hoursUntilCheckIn > 24) { %>
                                    <form action="/bookings/<%= booking._id %>/cancel" method="POST" class="cancel-form">
                                        <button type="submit" class="cancel-btn" onclick="return confirm('Are you sure you want to cancel this booking?')">Cancel</button>
                                    </form>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    <% } %>
</div>

<style>
.trips-nav {
    margin: 1rem 2rem 0 1rem;
}

.back-home-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #222222;
    text-decoration: none;
    font-size: 0.95rem;
    padding: 0.5rem 1rem;
    border-radius: 40px;
    border: 1px solid #dddddd;
    transition: all 0.2s ease;
    background-color: white;
}

.back-home-btn:hover {
    background-color: #f7f7f7;
    border-color: #222222;
}

.trips-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
}

.trip-tabs {
    display: flex;
    gap: 0.5rem;
    border: 1px solid #dddddd;
    border-radius: 40px;
    padding: 0.25rem;
}

.trip-tab {
    padding: 0.5rem 1.5rem;
    border-radius: 40px;
    text-decoration: none;
    color: #717171;
    transition: all 0.2s ease;
}

.trip-tab.active {
    background-color: #222222;
    color: white;
}

.trips-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.trip-card {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.5rem;
    border: 1px solid #dddddd;
    border-radius: 12px;
    overflow: hidden;
    background: white;
    transition: box-shadow 0.2s ease;
}

.trip-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.05);
}

.trip-image {
    height: 243px;
    overflow: hidden;
}

.trip-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.trip-card:hover .trip-image img {
    transform: scale(1.05);
}

.trip-details {
    padding: 1.5rem 1.5rem 1.5rem 0;
}

.trip-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
}

.trip-header h3 {
    font-size: 1.2rem;
    font-weight: 600;
    color: #222222;
}

.trip-status {
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 500;
}

.trip-status.confirmed {
    background-color: #e6f7e6;
    color: #00a699;
}

.trip-status.cancelled {
    background-color: #ffe6e6;
    color: #ff385c;
}

.trip-location {
    color: #717171;
    font-size: 0.95rem;
    margin-bottom: 1rem;
}

.trip-location i {
    color: #ff385c;
    margin-right: 0.3rem;
}

.trip-dates {
    display: flex;
    gap: 2rem;
    margin-bottom: 1rem;
}

.date-box {
    display: flex;
    flex-direction: column;
}

.date-box label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #717171;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
}

.date-box span {
    font-size: 0.95rem;
    color: #222222;
}

.trip-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid #dddddd;
    padding-top: 1rem;
}

.trip-price {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.price-label {
    color: #717171;
    font-size: 0.9rem;
}

.price-value {
    font-weight: 600;
    color: #222222;
    font-size: 1.1rem;
}

.trip-actions {
    display: flex;
    gap: 0.5rem;
}

.details-btn, .cancel-btn {
    padding: 0.5rem 1.2rem;
    border-radius: 40px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
    text-decoration: none;
}

.details-btn {
    background-color: #f7f7f7;
    color: #222222;
    border: 1px solid #dddddd;
}

.details-btn:hover {
    background-color: #222222;
    color: white;
    border-color: #222222;
}

.cancel-btn {
    background-color: #fff1f0;
    color: #ff385c;
    border: 1px solid #ff385c;
}

.cancel-btn:hover {
    background-color: #ff385c;
    color: white;
}

.cancel-form {
    display: inline;
}

@media (max-width: 768px) {
    .trips-nav {
        margin: 1rem 1rem 0 1rem;
    }
    
    .trips-header {
        flex-direction: column;
        align-items: flex-start;
    }
    
    .trip-card {
        grid-template-columns: 1fr;
    }
    
    .trip-image {
        height: 180px;
    }
    
    .trip-details {
        padding: 1rem;
    }
    
    .trip-dates {
        flex-direction: column;
        gap: 0.5rem;
    }
    
    .trip-footer {
        flex-direction: column;
        gap: 1rem;
        align-items: flex-start;
    }
    
    .trip-actions {
        width: 100%;
    }
    
    .details-btn, .cancel-btn {
        flex: 1;
        text-align: center;
    }
}
</style>