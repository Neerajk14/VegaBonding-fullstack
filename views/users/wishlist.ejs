<% layout("/layouts/boilerplate") %>

 <div class="wishlist-nav">
    <a href="/listings" class="back-home-btn">
        <i class="fa-solid fa-arrow-left"></i> Back to Home
    </a>
</div>

<div class="container mt-4">
    <h1 class="mb-4">My Wishlist</h1>
    
    <% if(wishlist.length === 0) { %>
        <div class="text-center py-5">
            <i class="fa-regular fa-heart" style="font-size: 4rem; color: #ff385c;"></i>
            <h3 class="mt-3">Your wishlist is empty</h3>
            <p class="text-muted">Save your favorite listings to see them here</p>
            <a href="/listings" class="btn btn-dark mt-3">Explore Listings</a>
        </div>
    <% } else { %>
        <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 mt-3">
            <% for(let listing of wishlist) { %>
                <div class="col mb-4">
                    <div class="card listing-card">
                        <div class="card-image-container">
                            <a href="/listings/<%= listing._id%>" class="listing-link">
                                <img 
                                    src="<%= listing.image.url %>" 
                                    class="card-img-top" 
                                    alt="listing_image"  
                                />
                            </a>
                            <button class="wishlist-btn" data-listing-id="<%= listing._id %>">
                                <i class="fa-solid fa-heart"></i>
                            </button>
                        </div>
                        <div class="card-body">
                            <a href="/listings/<%= listing._id%>" class="listing-link">
                                <div class="card-content">
                                    <div class="location-rating">
                                        <span class="location"><%= listing.location %>, <%= listing.country %></span>
                                        <span class="rating">
                                            <i class="fa-solid fa-star"></i> 
                                            <% 
                                                let avgRating = 0;
                                                if(listing.reviews && listing.reviews.length > 0) {
                                                    avgRating = (Math.random() * (5.0 - 4.0) + 4.0).toFixed(2);
                                                } else {
                                                    avgRating = "New";
                                                }
                                            %>
                                            <%= avgRating %>
                                        </span>
                                    </div>
                                    <div class="title"><%= listing.title %></div>
                                    <div class="dates">Nov 12-17</div>
                                    <div class="price-section">
                                        <% if (listing.price != null) { %>
                                            <span class="price">&#8377;<%= listing.price.toLocaleString("en-IN") %></span>
                                            <span class="night"> night</span>
                                        <% } %>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    <% } %>
</div>

<style>
    .wishlist-nav {
        margin: 1rem 2rem 0 1rem;
    }

    .back-home-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #222222;
        text-decoration: none;
        font-size: 0.95rem;
        padding: 0.5rem 1rem;
        border-radius: 40px;
        border: 1px solid #dddddd;
        transition: all 0.2s ease;
        background-color: white;
    }

    .back-home-btn:hover {
        background-color: #f7f7f7;
        border-color: #222222;
    }

    @media (max-width: 768px) {
        .wishlist-nav {
            margin: 1rem 1rem 0 1rem;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const wishlistBtns = document.querySelectorAll('.wishlist-btn');
        
        wishlistBtns.forEach(btn => {
            btn.addEventListener('click', async function(e) {
                e.preventDefault();
                e.stopPropagation();
                
                const listingId = this.dataset.listingId;
                const heartIcon = this.querySelector('i');
                
                this.style.transform = 'scale(0.9)';
                
                try {
                    const response = await fetch(`/api/wishlist/toggle/${listingId}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });
                    
                    const data = await response.json();
                    
                    if (data.status === 'removed') {
                        const card = this.closest('.col');
                        card.style.transition = 'opacity 0.3s ease';
                        card.style.opacity = '0';
                        setTimeout(() => {
                            card.remove();
                            if(document.querySelectorAll('.col').length === 0) {
                                location.reload();
                            }
                        }, 300);
                    }
                } catch (err) {
                    console.error('Error:', err);
                }
                
                setTimeout(() => {
                    this.style.transform = '';
                }, 200);
            });
        });
    });
</script>