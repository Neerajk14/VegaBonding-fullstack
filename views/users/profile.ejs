<% layout("/layouts/boilerplate") %>
<!-- Home/Back Button -->
<div class="profile-nav">
    <a href="/listings" class="back-home-btn">
        <i class="fa-solid fa-arrow-left"></i> Back to Home
    </a>
</div>

<div class="profile-container">
    <!-- Profile Header -->
    <div class="profile-header">
        <div class="profile-cover">
            <div class="profile-avatar">
                <span class="avatar-letter"><%= profileUser.username.charAt(0).toUpperCase() %></span>
            </div>
        </div>
        
        <div class="profile-info">
            <div class="profile-details">
                <h1 class="profile-name"><%= profileUser.username %></h1>
                <p class="profile-email">
                    <i class="fa-regular fa-envelope"></i> <%= profileUser.email %>
                </p>
                <p class="profile-member-since">
                    <i class="fa-regular fa-calendar"></i> Member since <%= new Date(profileUser.memberSince || Date.now()).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %>
                </p>
            </div>
        </div>
    </div>

    <!-- Profile Content -->
    <div class="profile-content">
        <!-- Wishlist and Logout Options -->
        <div class="profile-actions">
            <a href="/wishlist" class="action-btn">
                <i class="fa-solid fa-heart" ></i> View Wishlists
            </a>
            <a href="/trips" class="action-btn">
                <i class="fa-solid fa-plane-departure"></i>My Trips
            </a>
            <a href="/logout" class="action-btn logout-btn">
                <i class="fa-solid fa-arrow-right-from-bracket"></i> Logout
            </a>
        </div>

        <!-- Reviews Written Section -->
        <div class="profile-section">
            <h2 class="section-title">
                <i class="fa-regular fa-comments"></i> Reviews Written (<%= userReviews.length %>)
            </h2>
            
            <% if(userReviews.length > 0) { %>
                <div class="reviews-list">
                    <% for(let review of userReviews) { %>
                        <div class="review-card">
                            <div class="review-header">
                                <div class="review-listing-info">
                                    <i class="fa-regular fa-building"></i>
                                    <span>Reviewed a listing</span>
                                </div>
                                <span class="review-date">
                                    <%= new Date(review.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                </span>
                            </div>
                            
                            <div class="review-rating">
                                <% for(let i = 1; i <= 5; i++) { %>
                                    <i class="fa-<%= i <= review.rating ? 'solid' : 'regular' %> fa-star"></i>
                                <% } %>
                            </div>
                            
                            <p class="review-comment">"<%= review.comment %>"</p>
                            
                            <div class="review-actions">
                                <% if(review.listing && review.listing._id) { %>
                                    <a href="/listings/<%= review.listing._id %>" class="review-action-btn view-btn">
                                        <i class="fa-regular fa-eye"></i> View
                                    </a>
                                <% } %>
                                <form action="/reviews/<%= review._id %>?_method=DELETE" method="POST" class="delete-review-form">
                                    <button type="submit" class="review-action-btn delete-btn" onclick="return confirm('Are you sure you want to delete this review?')">
                                        <i class="fa-regular fa-trash-can"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <i class="fa-regular fa-star"></i>
                    <p>No reviews yet</p>
                </div>
            <% } %>
        </div>
    </div>
</div>