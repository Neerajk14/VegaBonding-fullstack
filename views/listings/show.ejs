<% layout("/layouts/boilerplate.ejs") %>


<div class="row mt-3">
  <div class="col-8 offset-3">
    <h3><%= listing.title %></h3>
  </div>
  <div class="card col-6 offset-3 show-card listing-card">
    <img src="<%= listing.image.url %>" class="card-img-top show-img" alt=" Listing_img" />
    <br />
    <div class="card-body">
      <p class="card-text" style="font-weight: bold ;">
        <i>Owned By -: @<%= listing.owner.username %></i>
      </p>
      <p class="card-text"><%= listing.description %></p>
      <p class="card-text">₹<%= listing.price.toLocaleString("en-IN")%></p>
      <p class="card-text"> <%= listing.location %> <br /></p>
      <p class="card-text"> <%=listing.country %></p>
    </div>
  </div>
</div>
<% if (currentUser && listing.owner._id.equals(currentUser._id)) { %>

<div class="btns">
  <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 edit-btn offset-3">Edit</a>
  <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
    <button class="btn btn-dark offset-5">Delete</button>
  </form>
</div>
<% } %>

<div class="col-8 offset-3 mb-3">
  <hr />
  <% if (currentUser) { %>

  <h4>Leave a Review</h4>
  <form action="/listings/<%= listing.id %>/reviews" method="POST" novalidate class="needs-validation">
    <div class="rating mb-3 mt-3">
      <label for="rating" class="form-label" style="font-weight: bold ;">Rating</label><br>
      <input type="hidden" id="rating-value" name="review[rating]" class="form-control" />
      <i class="fa fa-star" data-value="1"></i>
      <i class="fa fa-star" data-value="2"></i>
      <i class="fa fa-star" data-value="3"></i>
      <i class="fa fa-star" data-value="4"></i>
      <i class="fa fa-star" data-value="5"></i>
    </div>

    <div class="mb-3 mt-3">
      <label for="comment" class="form-label" style="font-weight: bold ;">Comments</label>
      <textarea name="review[comment]" id="comment" class="form-control" cols="30" rows="5" required></textarea>
      <div class="invalid-feedback">
        Please submit some comments for review..!
      </div>
    </div>
    <button class="btn btn-dark">Submit</button>
  </form>
  <hr>
  <% } %>

  <% if (listing.reviews.length >0) { %>
  <div class="row">
    <p><b>All Reviews</b></p>
    <% for( review of listing.reviews ) { %>
    <div class="card col-5 mb-3 ms-3">
      <div class="card-body">
        <h5 class="card-title">@<%=review.author.username%></h5>
        <p class="card-text"><%= review.comment %></p>
        <p class="card-text">
          <% for (let i = 1; i <= 5; i++) { %>
          <% if (i <= review.rating) { %>
          <i class="fa fa-star text-warning"></i>
          <% } else { %>
          <i class="fa fa-star text-secondary"></i>
          <% } %>
          <% } %>
        </p>

      </div>
     
      <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="mb-3 mt-2">
        <% if (currentUser && review.author &&review.author._id.equals(currentUser._id)) { %>
        <button class="btn btn-sm btn-dark">Delete</button>
   
      <% } %>   </form>
       
    </div>
    <% } %>
  </div>
  <% } %>
</div>